# Supabase (получите на https://supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic API (получите на https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# JWT секрет (придумайте любую длинную строку)
JWT_SECRET=your-random-secret-string-at-least-32-chars
